{"id":"0b75937e-2f44-4e49-bd1e-3e3adbed6f84","model_name_ssi":"Document","model_pk_ssi":"33395c16-c64b-4671-99b1-8f18c9cc8441","gbl_mdVersion_s":"Aardvark","b1g_isHarvested_b":false,"dct_references_s":"{\"http://schema.org/url\":\"https://data.humdata.org/dataset/0b75937e-2f44-4e49-bd1e-3e3adbed6f84\"}","dct_title_s":"Damage assessment in Jindires, Afrin district, Aleppo Governorate, on February 11. تقييم الأضرار في جنديرس، منطقة عفرين، محافظة حلب في 11 فبراير Syrian Arab Republic: 2023","dct_description_sm":["**UNOSAT code EQ20230206SYR, GDACS Id: 1357372** توضح هذه الخريطة المباني التي يحتمل أنها تتضررت من جراء زلزال 06 فبراير 2023 في جنديرس في منطقة عفرين (محافظة حلب)، كما تم اكتشافها من صورة القمر الصناعي عالية الدقة Pleiades التي تم الحصول عليها في 11 فبراير 2023. في مدينة جنديرس، حدد يونوسات 228 مبنى متضررا و318 مبنى يحتمل أن يكون متضررا. هذا تحليل أولي ولم يتم التحقق من صحته بعد على الأرض. يرجى إرسال التعليقات الأرضية إلى مركز الأمم المتحدة للأقمار الصناعية (يونوسات)"],"b1g_dct_provenance_sm":["The metadata for this resource was last retrieved from Humanitarian Data Exchange on 2026-01-15."],"b1g_websitePlatform_s":"CKAN","b1g_dateAccessioned_dt":"2026-01-15T00:00:00Z","geomg_id_s":"0b75937e-2f44-4e49-bd1e-3e3adbed6f84","b1g_publication_state_s":"published","b1g_dct_accrualMethod_s":"Automated retrieval","pcdm_memberOf_sm":["b0153110-e455-4ced-9114-9b13250a7093"],"dct_isPartOf_sm":["99-1400"],"b1g_access_s":"{}","dct_temporal_sm":["2023-02-14"],"dct_issued_s":"2023-02-15","gbl_indexYear_im":[2023],"gbl_dateRange_drsim":["[2023 TO 2023]"],"gbl_suppressed_b":false,"b1g_deprioritized_b":false,"dct_spatial_sm":["Syrian Arab Republic"],"dcat_bbox":"ENVELOPE(35.700,42.350,37.230,32.310)","locn_geometry":"POLYGON((35.700 37.230, 42.350 37.230, 42.350 32.310, 35.700 32.310, 35.700 37.230))","b1g_dcat_endpointURL_s":"https://data.humdata.org/api/3/","dcat_centroid":"34.769999999999996,39.025000000000006","gbl_georeferenced_b":false,"b1g_dcat_endpointDescription_s":"CK