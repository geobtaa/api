{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Search endpointAPI Response",
  "type": "object",
  "required": ["status", "meta", "data"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error"]
    },
    "meta": {
      "type": "object",
      "required": ["pages", "queryTime", "spellingSuggestions"],
      "properties": {
        "pages": {
          "type": "object",
          "required": ["current_page", "total_pages", "total_count"],
          "properties": {
            "current_page": { "type": "integer" },
            "next_page": { "type": ["integer", "null"] },
            "prev_page": { "type": ["integer", "null"] },
            "total_pages": { "type": "integer" },
            "limit_value": { "type": "integer" },
            "offset_value": { "type": "integer" },
            "total_count": { "type": "integer" },
            "first_page?": { "type": "boolean" },
            "last_page?": { "type": "boolean" }
          }
        },
        "queryTime": {
          "type": "object",
          "properties": {
            "cache": { "type": "string" },
            "elasticsearch": { "type": "string" },
            "resourceProcessing": {
              "type": "object",
              "properties": {
                "total": { "type": "string" },
                "perResource": { "type": "string" },
                "thumbnailService": { "type": "string" },
                "citationService": { "type": "string" },
                "viewerService": { "type": "string" }
              }
            },
            "totalResponseTime": { "type": "string" },
            "postgresql": { "type": "string" }
          }
        },
        "spellingSuggestions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "id", "score", "attributes"],
        "properties": {
          "type": { "type": "string" },
          "id": { "type": "string" },
          "score": { "type": ["number", "integer"] },
          "attributes": {
            "type": "object",
            "description": "Aardvark fields will be defined here"
          }
        }
      }
    },
    "included": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "id", "attributes"],
        "properties": {
          "type": { "type": "string" },
          "id": { "type": "string" },
          "attributes": { "type": "object" }
        }
      }
    }
  },
  "additionalProperties": false
}
