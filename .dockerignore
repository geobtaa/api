# --- Caches (recursive) ---
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.ipynb_checkpoints/

# --- Python envs & builds ---
.venv/
**/.venv/
env/
**/env/
venv/
**/venv/
dist/
**/dist/
build/
**/build/
.eggs/
*.egg-info/
**/*.egg-info/

# --- Node/JS ---
node_modules/
**/node_modules/
*.tsbuildinfo
**/.vite/
**/.cache/
**/dist/
**/build/
**/coverage/
**/htmlcov/
**/*.map
**/dist/

# --- OS / editors ---
.DS_Store
.idea/
.vscode/

# --- Test / coverage ---
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# --- VCS & env files ---
.git
/.git/
.gitignore
.env
.env.*
/.kamal/

# --- Databases & data dumps (can be huge) ---
*.sqlite*
*.db
*.parquet
*.feather
*.arrow
*.csv
*.tsv
*.ndjson
*.gz
*.zip
*.tar
*.tar.gz

# --- Geospatial heavies ---
*.tif
*.tiff
*.gpkg
*.mbtiles
*.shp
*.prj
*.shx
*.dbf
*.geojson

# --- Logs ---
*.log
logs/
/logs/
/test_logs/
/tmp/

# --- Local runtime data dirs (don’t bake into image) ---
elasticsearch-data/
paradedb-data/
data/
/data/
backend/data/
backend/logs/
backend/tmp/
backend/coverage_html_report/
backend/htmlcov/
backend/test_logs/
frontend/.git/
frontend/.react-router/
frontend/coverage/
frontend/dist/

# --- Top-level projects not needed in the Kamal app image ---
/cli/
/docs/
/mkdocs/
/performance/
/qgis-plugin/
/qgis-plugin.zip

# --- Optional: keep small in-repo samples available to builds ---
#!samples/**
